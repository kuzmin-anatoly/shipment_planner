APP_ENV=local
APP_NAME=AI Platform MVP

# LiteLLM exposes an OpenAI-compatible API for local models.
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=sk-local-dev
LLM_MODEL=qwen2.5:3b
LLM_OFFLINE_FALLBACK=true
LLM_TIMEOUT_SECONDS=180

LITELLM_MASTER_KEY=sk-local-dev
# Optional integrations. Leave empty for local sandbox mode.
CONFLUENCE_BASE_URL=
CONFLUENCE_API_TOKEN=
JIRA_BASE_URL=
JIRA_API_TOKEN=
GITLAB_BASE_URL=
GITLAB_TOKEN=
